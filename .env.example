# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# --- Convex ---
# Set by `pnpm -F @cataster/backend dev` after selecting a deployment.
# @see https://docs.convex.dev/quickstart
CONVEX_DEPLOYMENT=""
VITE_CONVEX_URL="https://<your-deployment>.convex.cloud"

# --- Clerk ---
# @see https://clerk.com/docs/quickstarts/tanstack-react-start
# Dashboard > API Keys. Publishable key is exposed to the browser.
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Used by Convex to verify Clerk-issued JWTs.
# Dashboard > JWT Templates > create a "convex" template and copy the issuer URL.
# Dev: https://verb-noun-00.clerk.accounts.dev — Prod: https://clerk.<your-domain>.com
# @see https://docs.convex.dev/auth/clerk
CLERK_JWT_ISSUER_DOMAIN="https://verb-noun-00.clerk.accounts.dev"
